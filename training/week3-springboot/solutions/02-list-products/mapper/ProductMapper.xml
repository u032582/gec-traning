<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  このファイルの置き場所: src/main/resources/mapper/ProductMapper.xml
  これは「やり方A（2メソッドに分ける）」の解答です。
  「やり方B（動的SQLで1メソッド）」は、このフォルダの README.md に別途載せています。
-->
<mapper namespace="com.example.training.product.ProductMapper">

    <!-- IDで商品1件 -->
    <select id="findById" resultType="com.example.training.product.Product">
        SELECT product_id, name, price, category_id
          FROM products
         WHERE product_id = #{productId}
    </select>

    <!-- 全件（id昇順） -->
    <select id="findAll" resultType="com.example.training.product.Product">
        SELECT product_id, name, price, category_id
          FROM products
         ORDER BY product_id
    </select>

    <!-- カテゴリ絞り込み（id昇順） -->
    <select id="findByCategory" resultType="com.example.training.product.Product">
        SELECT product_id, name, price, category_id
          FROM products
         WHERE category_id = #{categoryId}
         ORDER BY product_id
    </select>

</mapper>
